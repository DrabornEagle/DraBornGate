{
  "expo": {
    "name": "DraBornGate",
    "slug": "draborngate",
    "version": "0.3.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "draborngate",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#06101D"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.draborneagle.draborngate"
    },
    "android": {
      "package": "com.draborneagle.draborngate",
      "versionCode": 1,
      "softwareKeyboardLayoutMode": "resize",
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#06101D"
      }
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "DraBornGate profil fotoğrafı, teslimat görseli ve ödeme dekontu seçebilmek için fotoğraflarınıza erişir.",
          "cameraPermission": "DraBornGate selfie veya teslimat görseli çekebilmek için kameraya erişir.",
          "microphonePermission": false
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "DraBornGate site konumunu haritada seçmek ve akıllı geçiş mesafesini kontrol etmek için konumunu yalnızca uygulama açıkken kullanır.",
          "isAndroidBackgroundLocationEnabled": false,
          "isIosBackgroundLocationEnabled": false
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#37D8FF",
          "defaultChannel": "draborngate-core"
        }
      ]
    ],
    "extra": {
      "appVersion": "0.3.1",
      "demoDataVersion": "0.3.1",
      "androidVersionCode": 1
    }
  }
}
