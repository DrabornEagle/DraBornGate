{
  "expo": {
    "name": "DraBornGate",
    "slug": "draborngate",
    "version": "0.0.2",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "draborngate",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#06101D"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.draborneagle.draborngate"
    },
    "android": {
      "package": "com.draborneagle.draborngate",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#06101D"
      }
    },
    "plugins": ["expo-image-picker"],
    "extra": {
      "appVersion": "0.0.2",
      "demoDataVersion": "0.0.2",
      "androidVersionCode": 1
    }
  }
}
